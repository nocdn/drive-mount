{
  "name": "cloud-drive-mount",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "prepare:sidecars": "bun scripts/download-rclone.mjs",
    "build:frontend": "tsc && vite build",
    "test:frontend": "bun test tests",
    "dev": "vite",
    "build": "bun run prepare:sidecars && bun run build:frontend",
    "build:installer": "tauri build",
    "build:installer:mac": "tauri build --bundles dmg",
    "build:installer:windows": "tauri build --bundles msi",
    "build:installer:open": "bun scripts/build-open-installer.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons:generate": "tauri icon src-tauri/app-icon.svg -o src-tauri/icons"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "~2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "vite": "^6.0.3",
    "typescript": "~5.6.2"
  }
}
