<Window x:Class="CloudDriveMount.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cloud Drive Mount - Settings"
        Height="580"
        Width="560"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Label Content="B2 Application Key ID" Padding="0,0,0,2"/>
            <TextBox x:Name="TxtKeyId" Height="23" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center"/>

            <Label Content="B2 Application Key" Padding="0,0,0,2"/>
            <TextBox x:Name="TxtKey" Height="23" Margin="0,0,0,10" Padding="3,0" VerticalContentAlignment="Center"/>

            <Label Content="Buckets" Padding="0,0,0,2"/>
            <TextBlock Margin="0,0,0,6" Text="Each bucket is mounted directly to its own drive letter." TextWrapping="Wrap"/>
            <ScrollViewer Margin="0,0,0,0" VerticalScrollBarVisibility="Auto" MaxHeight="140">
                <StackPanel x:Name="BucketsPanel"/>
            </ScrollViewer>

            <Button x:Name="BtnAddBucket" Content="+ Add Bucket" Click="BtnAddBucket_Click" Margin="0,8,0,8" HorizontalAlignment="Left" Padding="8,2"/>

            <CheckBox x:Name="ChkStartOnLogin" Content="Start at login" Margin="0,0,0,5"/>
            <CheckBox x:Name="ChkStartMinimized" Content="Start minimized to tray" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnSaveMount" Content="Save and Mount All" Click="BtnSaveMount_Click" Margin="0,0,5,0" Padding="10,3"/>
                <Button x:Name="BtnUnmount" Content="Unmount All" Click="BtnUnmount_Click" Margin="0,0,5,0" Padding="10,3"/>
                <Button x:Name="BtnOpenLogs" Content="Open Log Folder" Click="BtnOpenLogs_Click" Margin="0,0,5,0" Padding="10,3"/>
                <Button x:Name="BtnClearLogs" Content="Clear Logs" Click="BtnClearLogs_Click" Padding="10,3"/>
            </StackPanel>

            <Label Content="Logs" Padding="0,0,0,2"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas"/>
        </ScrollViewer>
    </Grid>
</Window>
