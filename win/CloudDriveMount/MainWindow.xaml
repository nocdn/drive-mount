<Window x:Class="CloudDriveMount.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cloud Drive Mount - Settings"
        Height="740"
        Width="560"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Label Content="Provider" Padding="0,0,0,2"/>
            <ComboBox x:Name="CmbProvider" Height="23" Margin="0,0,0,8" SelectionChanged="CmbProvider_SelectionChanged">
                <ComboBoxItem Content="B2"/>
                <ComboBoxItem Content="Google Drive"/>
                <ComboBoxItem Content="Seedbox"/>
            </ComboBox>

            <StackPanel x:Name="B2OptionsPanel">
                <Label Content="B2 Application Key ID" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtKeyId" Height="23" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>

                <Label Content="B2 Application Key" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtKey" Height="23" Margin="0,0,0,10" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>

                <Label Content="Buckets" Padding="0,0,0,2"/>
                <TextBlock Margin="0,0,0,6" Text="Each bucket is mounted directly to its own drive letter." TextWrapping="Wrap"/>
                <ScrollViewer Margin="0,0,0,0" VerticalScrollBarVisibility="Auto" MaxHeight="140">
                    <StackPanel x:Name="BucketsPanel"/>
                </ScrollViewer>

                <Button x:Name="BtnAddBucket" Content="+ Add Bucket" Click="BtnAddBucket_Click" Margin="0,8,0,8" HorizontalAlignment="Left" Padding="8,2"/>
            </StackPanel>

            <StackPanel x:Name="GoogleDriveOptionsPanel" Visibility="Collapsed">
                <Label Content="Google Drive Folder Path (optional)" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtGoogleRemotePath" Height="23" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>

                <Label Content="Google Drive Root Folder ID (optional)" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtGoogleRootFolderId" Height="23" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>

                <TextBlock x:Name="TxtGoogleConnectHelp" Margin="0,0,0,8" Text="Click Connect Google Drive and sign in through the browser. After it connects, use Save and Mount All. Google Drive mounts to G:." TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BtnConnectGoogleDrive" Content="Connect Google Drive" Click="BtnConnectGoogleDrive_Click" Margin="0,0,5,0" HorizontalAlignment="Left" Padding="8,2"/>
                    <Button x:Name="BtnTestGoogleDriveConnection" Content="Test Connection" Click="BtnTestGoogleDriveConnection_Click" Visibility="Collapsed" HorizontalAlignment="Left" Padding="8,2"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="SeedboxOptionsPanel" Visibility="Collapsed">
                <Label Content="Seedbox Host" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtSeedboxHost" Height="23" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>

                <Label Content="Seedbox Username" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtSeedboxUsername" Height="23" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>

                <Label Content="FTPS Password" Padding="0,0,0,2"/>
                <PasswordBox x:Name="PwdSeedboxPassword" Height="23" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center" PasswordChanged="SeedboxPassword_Changed"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <StackPanel Width="90" Margin="0,0,10,0">
                        <Label Content="Port" Padding="0,0,0,2"/>
                        <TextBox x:Name="TxtSeedboxPort" Height="23" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>
                    </StackPanel>
                    <StackPanel Width="90">
                        <Label Content="Drive" Padding="0,0,0,2"/>
                        <TextBox x:Name="TxtSeedboxDriveLetter" Height="23" MaxLength="3" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>
                    </StackPanel>
                </StackPanel>

                <Label Content="Remote Folder" Padding="0,0,0,2"/>
                <TextBox x:Name="TxtSeedboxRemotePath" Height="23" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center" TextChanged="AnyMountField_Changed"/>

                <CheckBox x:Name="ChkSeedboxReadOnly" Content="Mount read-only" Margin="0,0,0,5" Checked="AnySeedboxOption_Changed" Unchecked="AnySeedboxOption_Changed"/>
                <CheckBox x:Name="ChkSeedboxAllowUnverified" Content="Allow unverified FTPS certificate" Margin="0,0,0,8" Checked="AnySeedboxOption_Changed" Unchecked="AnySeedboxOption_Changed"/>

                <TextBlock x:Name="TxtSeedboxConnectHelp" Margin="0,0,0,8" Text="Use your Ultra.cc FTP/SFTP connection details. Host is usually your server name, port is 21, and Remote Folder is usually downloads." TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BtnTestSeedboxConnection" Content="Test Connection" Click="BtnTestSeedboxConnection_Click" Margin="0,0,5,0" HorizontalAlignment="Left" Padding="8,2"/>
                    <Button x:Name="BtnForgetSeedbox" Content="Forget Seedbox" Click="BtnForgetSeedbox_Click" Visibility="Collapsed" HorizontalAlignment="Left" Padding="8,2"/>
                </StackPanel>
            </StackPanel>

            <CheckBox x:Name="ChkStartOnLogin" Content="Start at login" Margin="0,0,0,5"/>
            <CheckBox x:Name="ChkStartMinimized" Content="Start minimized to tray" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnSaveMount" Content="Save and Mount All" Click="BtnSaveMount_Click" Margin="0,0,5,0" Padding="10,3"/>
                <Button x:Name="BtnUnmount" Content="Unmount All" Click="BtnUnmount_Click" Margin="0,0,5,0" Padding="10,3"/>
                <Button x:Name="BtnOpenLogs" Content="Open Log Folder" Click="BtnOpenLogs_Click" Margin="0,0,5,0" Padding="10,3"/>
                <Button x:Name="BtnClearLogs" Content="Clear Logs" Click="BtnClearLogs_Click" Margin="0,0,5,0" Padding="10,3"/>
                <Button x:Name="BtnRestart" Content="Restart" Click="BtnRestart_Click" Padding="10,3"/>
            </StackPanel>

            <Label Content="Logs" Padding="0,0,0,2"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas"/>
        </ScrollViewer>
    </Grid>
</Window>
