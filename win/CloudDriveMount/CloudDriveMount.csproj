<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <AssemblyName>CloudDriveMount</AssemblyName>
    <AssemblyTitle>Cloud Drive Mount</AssemblyTitle>
    <Product>Cloud Drive Mount</Product>
    <Copyright>CloudDriveMount</Copyright>
  </PropertyGroup>

  <Target Name="EnsureRclone" BeforeTargets="BeforeBuild;PrepareForPublish" Condition="!Exists('$(MSBuildProjectDirectory)\rclone.exe')">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$ErrorActionPreference='Stop'; $projectDir='$(MSBuildProjectDirectory)'; $dest=Join-Path $projectDir 'rclone.exe'; if (Test-Path $dest) { exit 0 }; $release=Invoke-RestMethod -Uri 'https://api.github.com/repos/rclone/rclone/releases/latest' -Headers @{ 'User-Agent'='PowerShell' }; $asset=$release.assets | Where-Object { $_.name -match 'windows-amd64.*\.zip$' } | Select-Object -First 1; if (-not $asset) { throw 'Could not find rclone windows-amd64 release asset.' }; $temp=Join-Path ([IO.Path]::GetTempPath()) ([IO.Path]::GetRandomFileName()); New-Item -ItemType Directory -Path $temp | Out-Null; try { $zip=Join-Path $temp 'rclone.zip'; Invoke-WebRequest -Uri $asset.browser_download_url -OutFile $zip -UseBasicParsing; Expand-Archive -Path $zip -DestinationPath $temp -Force; $found=Get-ChildItem -Path $temp -Recurse -Filter 'rclone.exe' | Select-Object -First 1; if (-not $found) { throw 'rclone.exe not found in downloaded archive.' }; Copy-Item -Path $found.FullName -Destination $dest -Force } finally { Remove-Item -Recurse -Force $temp -ErrorAction SilentlyContinue }&quot;" />
  </Target>

  <!-- rclone must be shipped next to the app because the app launches it as a separate process. -->
  <ItemGroup>
    <Content Include="rclone.exe" Condition="Exists('rclone.exe')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
  </ItemGroup>
</Project>
